root = true

[**/build/generated/**.kt]
ktlint = disabled

[*.{kt,kts}]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120
ij_kotlin_imports_layout = *

ktlint_function_naming_ignore_when_annotated_with = Composable